# VITE_SITE_URL: the production domain this site is deployed at.
# Drives canonical URLs and Open Graph tags (see src/lib/siteConfig.ts).
VITE_SITE_URL="https://www.tropsimmo.com"

# VITE_WEB3FORMS_ACCESS_KEY: access key for the contact form (see src/components/ContactView.tsx).
# Get a free key at https://web3forms.com by entering the destination inbox
# (e.g. contact@tropsimmo.dz) — no account/backend needed. Without this key
# set, the contact form will show a submission error instead of sending.
VITE_WEB3FORMS_ACCESS_KEY=""
